---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@comp/Header.astro';
import Footer from '@comp/Footer.astro';

export const prerender = true;

const aiArtImages = [
  { id: 1, link: 'https://www.instagram.com/p/CgteaChDpDK/', src: '/photos/ai-art/1.jpg', w: 1024, h: 1024 },
  { id: 2, link: 'https://www.instagram.com/p/CgteaChDpDK/', src: '/photos/ai-art/2.jpg', w: 1024, h: 1024 },
  { id: 3, link: 'https://www.instagram.com/p/CgteaChDpDK/', src: '/photos/ai-art/3.jpg', w: 1024, h: 1024 },
  { id: 4, link: 'https://www.instagram.com/p/CgteaChDpDK/', src: '/photos/ai-art/4.jpg', w: 1024, h: 1024 },
  { id: 5, link: 'https://www.instagram.com/p/ClZa6Qno4kR/', src: '/photos/ai-art/5.jpeg', w: 1024, h: 1024 },
  { id: 6, link: 'https://www.instagram.com/p/ClZa6Qno4kR/', src: '/photos/ai-art/6.jpg', w: 1024, h: 1024 },
  { id: 7, link: 'https://www.instagram.com/p/ClZa6Qno4kR/', src: '/photos/ai-art/7.jpg', w: 1024, h: 1024 },
  { id: 8, link: 'https://www.instagram.com/p/ClZa6Qno4kR/', src: '/photos/ai-art/8.jpg', w: 1024, h: 1024 },
  { id: 9, link: 'https://www.instagram.com/p/CleQo3pMa_V/', src: '/photos/ai-art/9.jpg', w: 1024, h: 1024 },
  { id: 10, link: 'https://www.instagram.com/p/CleQo3pMa_V/', src: '/photos/ai-art/10.jpg', w: 1024, h: 1024 },
  { id: 11, link: 'https://www.instagram.com/p/CleQo3pMa_V/', src: '/photos/ai-art/11.jpg', w: 1024, h: 1024 },
  { id: 12, link: 'https://www.instagram.com/p/CleQo3pMa_V/', src: '/photos/ai-art/12.jpg', w: 1024, h: 1024 },
  { id: 13, link: 'https://www.instagram.com/p/ChB_uH6DegZ/', src: '/photos/ai-art/13.jpg', w: 1024, h: 1024 },
  { id: 14, link: 'https://www.instagram.com/p/ChB_uH6DegZ/', src: '/photos/ai-art/14.jpg', w: 1024, h: 1024 },
  { id: 15, link: 'https://www.instagram.com/p/ChB_uH6DegZ/', src: '/photos/ai-art/15.jpg', w: 1024, h: 1024 },
  { id: 16, link: 'https://www.instagram.com/p/ChB_uH6DegZ/', src: '/photos/ai-art/16.jpg', w: 1024, h: 1024 },
];
---

<BaseLayout title="AI Art" description="A gallery of generative AI artwork created by Çalgan Aygün.">
  <Fragment slot="header">
    <Header />
  </Fragment>

  <div class="c-small">
    <h1 class="text-2xl text-highlight">
      You can find some of the images I created and shared on my account using stable diffusion/generative AI tools here.
    </h1>
  </div>

  <div class="c-large mt-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {aiArtImages.map((item) => (
        <div class="mb-8">
          <a href={item.link} target="_blank" rel="noopener noreferrer" aria-label={`View generative AI artwork ${item.id} on Instagram`}>
            <img
              src={item.src}
              alt={`Generative AI artwork ${item.id}`}
              width={item.w}
              height={item.h}
              loading="lazy"
              decoding="async"
              class="w-full h-auto rounded"
            />
          </a>
        </div>
      ))}
    </div>
  </div>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
